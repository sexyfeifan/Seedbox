# Backend
NODE_ENV=development
PORT=12333
JWT_SECRET=replace_me
STORE_DRIVER=memory
INTERNAL_API_TOKEN=seedbox-dev-token

# Postgres
DATABASE_URL=postgresql://seedbox:seedbox@localhost:5432/seedbox

# Redis
REDIS_URL=redis://localhost:6379

# Storage (S3/MinIO)
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=seedbox
S3_ACCESS_KEY=seedbox
S3_SECRET_KEY=seedbox123
S3_FORCE_PATH_STYLE=true

# AI
OPENAI_API_KEY=replace_me
OPENAI_MODEL=gpt-5-mini

# Observability
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_RELEASE=seedbox-backend@dev

# Parser
PLAYWRIGHT_TIMEOUT_MS=20000
WORKER_MODE=api
API_BASE_URL=http://127.0.0.1:12333
WORKER_POLL_INTERVAL_MS=3000
