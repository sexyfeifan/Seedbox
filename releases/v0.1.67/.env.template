# Seedbox v0.1.67 环境变量模板
# 使用方法：复制为同目录 `.env`，再配合 docker-compose.yml 启动
# 标记说明：
# 🔴 = 建议你自行修改
# 🟡 = 按需修改
# 🟢 = 可以直接用

# ------------------------------
# 服务访问
# ------------------------------
# 🟡 宿主机暴露端口；默认 12333
SEEDBOX_HOST_PORT=12333

# ------------------------------
# 服务间通信
# ------------------------------
# 🔴 后端与 parser-worker 内部通信令牌；两个服务必须一致
INTERNAL_API_TOKEN=please-change-this-token

# 🔴 客户端访问令牌；如果你会经由公网访问，强烈建议保留非空
# Web 端首次使用时，需要在浏览器 localStorage 或请求头里带上这个值
CLIENT_ACCESS_TOKEN=please-change-this-client-token

# ------------------------------
# 版本号
# ------------------------------
# 🟢 统一发布版本号
SEEDBOX_RELEASE_VERSION=v0.1.67
# 🟢 后端版本号
SEEDBOX_BACKEND_VERSION=v0.1.67
# 🟢 解析器版本号
SEEDBOX_PARSER_VERSION=v0.1.67

# ------------------------------
# 功能开关
# ------------------------------
# 🟢 是否启用商业模式界面；自用部署建议 false
COMMERCIAL_MODE_ENABLED=false
# 🟢 是否启用 Playwright 动态回退；建议保持 true
ENABLE_PLAYWRIGHT_FALLBACK=true

# ------------------------------
# 抓取超时与轮询
# ------------------------------
# 🟢 分享链接解析超时（毫秒）
CAPTURE_RESOLVE_TIMEOUT_MS=12000
# 🟢 媒体回源抓取超时（毫秒）
ASSET_FETCH_TIMEOUT_MS=30000
# 🟢 parser 轮询间隔（毫秒）
WORKER_POLL_INTERVAL_MS=3000

# ------------------------------
# 本地缓存持久化
# ------------------------------
# 🟢 媒体缓存目录（容器内路径）；会映射到你挂载的 /data 下
ASSET_CACHE_DIR=/data/asset_cache
# 🟢 站点图标缓存目录（容器内路径）
SITE_ICON_CACHE_DIR=/data/site_icon_cache

# ------------------------------
# 豆瓣相关
# ------------------------------
# 🟢 豆瓣最小请求间隔（毫秒）
DOUBAN_MIN_REQUEST_INTERVAL_MS=4000
# 🟢 豆瓣请求抖动（毫秒）
DOUBAN_REQUEST_JITTER_MS=1200
# 🔴 豆瓣 Cookie；如果你希望豆瓣抓取更稳定，再填你自己的值
# 注意：如果值里含有 $，在 .env 中要写成 $$
DOUBAN_COOKIE=

# ------------------------------
# 噪音资源过滤
# ------------------------------
# 🟡 额外噪音资源规则；通常留空即可
EXTRA_NOISE_ASSET_PATTERNS=
