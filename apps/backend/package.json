{
  "name": "@seedbox/backend",
  "version": "0.1.57",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "start": "node dist/main.js",
    "start:memory": "npm run build && STORE_DRIVER=memory node dist/main.js",
    "start:postgres": "npm run build && STORE_DRIVER=postgres node dist/main.js",
    "build": "tsc -p tsconfig.json",
    "db:init": "tsx src/scripts/init-db.ts"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.1",
    "@fastify/sensible": "^6.0.3",
    "fastify": "^5.2.1",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.16.3",
    "pino-pretty": "^13.0.0",
    "zod": "^4.1.5"
  },
  "devDependencies": {
    "@types/node": "^24.3.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/pg": "^8.15.5",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2"
  }
}
